{
  "info": {
    "name": "TaskMng Phase 1 Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"Password123\",\n  \"confirmPassword\": \"Password123\",\n  \"fullName\": \"Owner User\",\n  \"companyName\": \"Acme SME\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/register"
      }
    },
    {
      "name": "Verify Email",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/verify-email"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"Password123\",\n  \"rememberMe\": true\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/auth/me"
      }
    },
    {
      "name": "Refresh",
      "request": {
        "method": "POST",
        "header": [{ "key": "Origin", "value": "http://localhost:3000" }],
        "url": "{{baseUrl}}/api/v1/auth/refresh"
      }
    },
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/forgot-password"
      }
    },
    {
      "name": "Select Company",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"companyId\": \"{{companyId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/select-company"
      }
    },
    {
      "name": "Invite Member",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"member@example.com\",\n  \"roleKey\": \"member\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/companies/{{companyId}}/invitations"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "accessToken", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "verificationToken", "value": "" }
  ]
}
