NODE_ENV=test
PORT=4001
APP_NAME=taskmng-backend-test
APP_URL=http://localhost:4001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/taskmng_test?schema=public
JWT_ACCESS_SECRET=replace-with-test-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=14
REFRESH_TOKEN_REMEMBER_DAYS=30
REFRESH_TOKEN_ABSOLUTE_DAYS=60
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
BODY_SIZE_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=1000
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1
INVITATION_TTL_HOURS=72
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
LOG_LEVEL=silent
ENABLE_SWAGGER=false
