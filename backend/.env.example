NODE_ENV=development
PORT=4000
APP_NAME=taskmng-backend
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/taskmng?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=14
REFRESH_TOKEN_REMEMBER_DAYS=30
REFRESH_TOKEN_ABSOLUTE_DAYS=60
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
BODY_SIZE_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1
INVITATION_TTL_HOURS=72
# false = đăng ký xong đăng nhập ngay; true = bắt buộc verify email (bật khi có domain Resend)
REQUIRE_EMAIL_VERIFICATION=false
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
# Optional: enhance smart task capture (deterministic parser works without a key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
LOG_LEVEL=info
ENABLE_SWAGGER=true
# Attachments: local (default/dev/test) or s3 (MinIO/AWS)
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=.data/attachments
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=taskmng-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
ATTACHMENT_MAX_BYTES=10485760
ATTACHMENT_SIGNED_URL_TTL_SECONDS=300
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=20
WORKER_MAX_ATTEMPTS=5
WORKER_ENABLED=true
