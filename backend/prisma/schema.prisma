generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  LOCKED
  DISABLED
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
}

enum WorkspaceType {
  PERSONAL
  ORGANIZATION
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OneTimeTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OnboardingType {
  PERSONAL_OWNER
  ORGANIZATION_OWNER
  INVITED_MEMBER
  INVITED_MANAGER
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  AI_QUICK_CAPTURE
  ONBOARDING
  RECURRING
}

enum ActivityVisibility {
  WORKSPACE
  ACTOR_ONLY
}

enum ProjectVisibility {
  WORKSPACE
  PRIVATE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectRole {
  PROJECT_OWNER
  PROJECT_MANAGER
  PROJECT_MEMBER
  PROJECT_VIEWER
}

enum ProjectHealth {
  GOOD
  AT_RISK
  CRITICAL
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkflowStageCategory {
  BACKLOG
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TemplateVisibility {
  WORKSPACE
  SYSTEM
}

enum CloneJobStatus {
  PENDING
  PROCESSING
  RETRY_WAIT
  COMPLETED
  FAILED
  DEAD
  CANCELLED
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_MENTIONED
  TASK_UNBLOCKED
  RECURRENCE_CREATED
  RECURRENCE_SKIPPED
  SLA_WARNING
  SLA_BREACHED
  RISK_ESCALATED
  PROJECT_STATUS_CHANGED
}

enum CustomFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
  MULTI_SELECT
  USER
}

enum AttachmentScanStatus {
  PENDING
  CLEAN
  REJECTED
}

enum DependencyType {
  FINISH_TO_START
}

enum DependencyCompletionPolicy {
  WARN_ONLY
  BLOCK
  BLOCK_WITH_OVERRIDE
}

enum TimeLogSource {
  TIMER
  MANUAL
  IMPORT
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum RecurrenceOverlapPolicy {
  CREATE_ANYWAY
  SKIP_IF_OPEN
  CREATE_AND_NOTIFY
}

enum RecurrenceOccurrenceStatus {
  PENDING
  CREATED
  SKIPPED
  FAILED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SlaInstanceStatus {
  ACTIVE
  PAUSED
  MET
  BREACHED
  CANCELLED
}

enum AutomationJobType {
  RECURRENCE_GENERATE
  RISK_RECALCULATE
  SLA_WARNING
  SLA_BREACH
  RETRY
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  DEAD
}

enum SavedViewResourceType {
  TASK
}

enum SavedViewType {
  LIST
  BOARD
  CALENDAR
  TIMELINE
}

enum SavedViewVisibility {
  PRIVATE
}

model User {
  id                    String     @id @default(uuid()) @db.Uuid
  email                 String     @unique
  passwordHash          String
  fullName              String
  status                UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  passwordChangedAt     DateTime?
  authVersion           Int        @default(0)
  failedLoginAttempts   Int        @default(0)
  lockedUntil           DateTime?
  lastActiveWorkspaceId String?    @db.Uuid
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  memberships              WorkspaceMember[]
  refreshSessions          RefreshSession[]
  ownedWorkspaces          Workspace[]              @relation("WorkspaceOwner")
  oneTimeTokens            OneTimeToken[]
  invitationsSent          WorkspaceInvitation[]    @relation("InvitationInviter")
  auditLogs                AuditLog[]
  activityEvents           ActivityEvent[]
  onboardings              WorkspaceOnboarding[]
  projectMemberships       ProjectMember[]
  projectMembersAdded      ProjectMember[]          @relation("ProjectMemberAddedBy")
  managedProjects          Project[]                @relation("ProjectManager")
  projectsCreated          Project[]                @relation("ProjectCreator")
  tasksCreated             Task[]                   @relation("TaskCreator")
  tasksAssigned            Task[]                   @relation("TaskAssignee")
  tasksCompleted           Task[]                   @relation("TaskCompleter")
  notifications            Notification[]
  notificationPrefs        NotificationPreference[]
  savedViews               SavedView[]
  checklistItemsCreated    ChecklistItem[]          @relation("ChecklistItemCreator")
  checklistItemsCompleted  ChecklistItem[]          @relation("ChecklistItemCompleter")
  tagsCreated              Tag[]                    @relation("TagCreator")
  customFieldValuesUpdated TaskCustomFieldValue[]   @relation("CustomFieldValueUpdater")
  commentsAuthored         Comment[]                @relation("CommentAuthor")
  attachmentsUploaded      Attachment[]             @relation("AttachmentUploader")
  taskDependenciesCreated  TaskDependency[]         @relation("TaskDependencyCreator")
  dependencyOverrides      Task[]                   @relation("TaskDependencyOverrider")
  timeLogs                 TimeLog[]
  taskStatusChanges        TaskStatusHistory[]      @relation("TaskStatusChanger")
  taskRecurrencesCreated   TaskRecurrence[]         @relation("TaskRecurrenceCreator")
  riskRulesUpdated         RiskRule[]               @relation("RiskRuleUpdater")
  businessCalendarsCreated BusinessCalendar[]       @relation("BusinessCalendarCreator")
  slaPoliciesCreated       SlaPolicy[]              @relation("SlaPolicyCreator")
  automationRunsRetried    AutomationRun[]          @relation("AutomationRunRetrier")
  workflowsCreated        Workflow[]               @relation("WorkflowCreator")
  projectTemplatesCreated ProjectTemplate[]        @relation("ProjectTemplateCreator")
  cloneJobsCreated        CloneJob[]               @relation("CloneJobCreator")
  milestonesCreated       Milestone[]              @relation("MilestoneCreator")
  lastActiveWorkspace      Workspace?               @relation("UserLastActiveWorkspace", fields: [lastActiveWorkspaceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([lastActiveWorkspaceId])
  @@map("users")
}

model Workspace {
  id                         String                     @id @default(uuid()) @db.Uuid
  name                       String
  slug                       String                     @unique
  type                       WorkspaceType              @default(ORGANIZATION)
  status                     WorkspaceStatus            @default(ACTIVE)
  ownerId                    String                     @db.Uuid
  industryCode               String?
  usagePurpose               String?
  companySize                String?
  timezone                   String                     @default("UTC")
  locale                     String                     @default("vi")
  logoUrl                    String?
  dependencyCompletionPolicy DependencyCompletionPolicy @default(WARN_ONLY)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?

  owner                   User                     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members                 WorkspaceMember[]
  roles                   Role[]
  invitations             WorkspaceInvitation[]
  onboardings             WorkspaceOnboarding[]
  modules                 WorkspaceModule[]
  projects                Project[]
  tasks                   Task[]
  activityEvents          ActivityEvent[]
  projectMembers          ProjectMember[]
  taskCounter             WorkspaceTaskCounter?
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  savedViews              SavedView[]
  tags                    Tag[]
  customFieldDefinitions  CustomFieldDefinition[]
  attachments             Attachment[]
  taskDependencies        TaskDependency[]
  timeLogs                TimeLog[]
  taskRecurrences         TaskRecurrence[]
  riskRules               RiskRule[]
  businessCalendars       BusinessCalendar[]
  slaPolicies             SlaPolicy[]
  taskSlaInstances        TaskSlaInstance[]
  automationRuns          AutomationRun[]
  workflows               Workflow[]
  projectTemplates        ProjectTemplate[]
  cloneJobs               CloneJob[]
  milestones              Milestone[]
  lastActiveUsers         User[]                   @relation("UserLastActiveWorkspace")

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@map("workspaces")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  key         String
  name        String
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members         WorkspaceMember[]
  rolePermissions RolePermission[]
  invitations     WorkspaceInvitation[]

  @@unique([workspaceId, key])
  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model WorkspaceMember {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  userId      String           @db.Uuid
  roleId      String           @db.Uuid
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId, workspaceId], references: [id, workspaceId])

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([roleId])
  @@index([workspaceId, status])
  @@map("workspace_members")
}

model RefreshSession {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  familyId            String    @db.Uuid
  tokenHash           String    @unique
  expiresAt           DateTime
  absoluteExpiresAt   DateTime
  rememberMe          Boolean   @default(false)
  revokedAt           DateTime?
  revokeReason        String?
  replacedByTokenHash String?
  lastUsedAt          DateTime?
  userAgent           String?
  ipAddress           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_sessions")
}

model OneTimeToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      OneTimeTokenType
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("one_time_tokens")
}

model WorkspaceInvitation {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  email       String
  roleId      String           @db.Uuid
  tokenHash   String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String           @db.Uuid
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId, workspaceId], references: [id, workspaceId])
  invitedBy User      @relation("InvitationInviter", fields: [invitedById], references: [id])

  @@index([workspaceId, email])
  @@index([status])
  @@index([expiresAt])
  @@map("workspace_invitations")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  workspaceId String?  @db.Uuid
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  requestId   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model WorkspaceOnboarding {
  id             String           @id @default(uuid()) @db.Uuid
  workspaceId    String           @db.Uuid
  userId         String           @db.Uuid
  onboardingType OnboardingType
  status         OnboardingStatus @default(IN_PROGRESS)
  currentStep    String
  completedSteps Json             @default("[]")
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([status])
  @@map("workspace_onboardings")
}

model WorkspaceModule {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  moduleKey   String
  enabled     Boolean  @default(true)
  core        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, moduleKey])
  @@index([workspaceId])
  @@map("workspace_modules")
}

model Project {
  id               String                     @id @default(uuid()) @db.Uuid
  workspaceId      String                     @db.Uuid
  name             String
  code             String?
  description      String?
  status           ProjectStatus              @default(ACTIVE)
  priority         TaskPriority               @default(MEDIUM)
  visibility       ProjectVisibility          @default(WORKSPACE)
  managerId        String?                    @db.Uuid
  startAt          DateTime?
  endAt            DateTime?
  completionPolicy DependencyCompletionPolicy @default(WARN_ONLY)
  completedAt      DateTime?
  archivedAt       DateTime?
  sourceCloneJobId String?                    @unique @db.Uuid
  createdById      String?                    @db.Uuid
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  deletedAt        DateTime?

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  manager                User?                   @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  creator                User?                   @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks                  Task[]
  members                ProjectMember[]
  customFieldDefinitions CustomFieldDefinition[]
  workflowsApplied      ProjectWorkflow[]
  workflowDrafts        Workflow[]               @relation("ProjectWorkflowDrafts")
  cloneJobs             CloneJob[]               @relation("CloneJobResultProject")
  sourceCloneJob        CloneJob?                 @relation("ProjectSourceCloneJob", fields: [sourceCloneJobId], references: [id], onDelete: SetNull)
  milestones            Milestone[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([workspaceId, status, deletedAt])
  @@index([workspaceId, managerId])
  @@index([workspaceId, archivedAt, deletedAt])
  @@index([createdById])
  @@map("projects")
}

model Workflow {
  id              String         @id @default(uuid()) @db.Uuid
  familyId        String         @default(uuid()) @db.Uuid
  workspaceId     String         @db.Uuid
  sourceProjectId String?        @db.Uuid
  name            String
  version         Int
  status          WorkflowStatus @default(DRAFT)
  createdById     String?        @db.Uuid
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceProject       Project?            @relation("ProjectWorkflowDrafts", fields: [sourceProjectId], references: [id], onDelete: Cascade)
  creator             User?               @relation("WorkflowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  stages              WorkflowStage[]
  transitions         WorkflowTransition[]
  projectApplications ProjectWorkflow[]

  @@unique([familyId, version])
  @@index([workspaceId, status])
  @@index([workspaceId, familyId])
  @@index([sourceProjectId, status])
  @@map("workflows")
}

model WorkflowStage {
  id          String                 @id @default(uuid()) @db.Uuid
  workflowId  String                 @db.Uuid
  name        String
  category    WorkflowStageCategory
  color       String?
  position    Int
  isInitial   Boolean                @default(false)
  isTerminal  Boolean                @default(false)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  workflow    Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tasks       Task[]

  fromTransitions WorkflowTransition[] @relation("TransitionFromStage")
  toTransitions   WorkflowTransition[] @relation("TransitionToStage")

  @@unique([workflowId, name])
  @@unique([workflowId, id])
  @@index([workflowId, position])
  @@map("workflow_stages")
}

model WorkflowTransition {
  id                String   @id @default(uuid()) @db.Uuid
  workflowId        String   @db.Uuid
  fromStageId       String   @db.Uuid
  toStageId         String   @db.Uuid
  requiredPermission String?
  conditionsJson    Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workflow     Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStage    WorkflowStage @relation("TransitionFromStage", fields: [workflowId, fromStageId], references: [workflowId, id], onDelete: Cascade)
  toStage      WorkflowStage @relation("TransitionToStage", fields: [workflowId, toStageId], references: [workflowId, id], onDelete: Cascade)

  @@index([workflowId, fromStageId])
  @@index([workflowId, toStageId])
  @@unique([workflowId, fromStageId, toStageId])
  @@map("workflow_transitions")
}

model ProjectWorkflow {
  projectId       String @id @db.Uuid
  workflowId      String @db.Uuid
  workflowVersion Int
  appliedAt       DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, appliedAt])
  @@map("project_workflows")
}

model Task {
  id                       String       @id @default(uuid()) @db.Uuid
  workspaceId              String       @db.Uuid
  taskNumber               Int
  projectId                String?      @db.Uuid
  parentTaskId             String?      @db.Uuid
  subtaskPosition          Int?
  milestoneId              String?      @db.Uuid
  title                    String
  description              String?
  status                   TaskStatus   @default(TODO)
  workflowStageId         String?       @db.Uuid
  priority                 TaskPriority @default(MEDIUM)
  startAt                  DateTime?
  dueDate                  DateTime?
  completedAt              DateTime?
  completedById            String?      @db.Uuid
  isBlocked                Boolean      @default(false)
  blockedReason            String?
  dependencyBlocked        Boolean      @default(false)
  dependencyOverrideReason String?
  dependencyOverriddenById String?      @db.Uuid
  dependencyOverriddenAt   DateTime?
  source                   TaskSource   @default(MANUAL)
  createdById              String?      @db.Uuid
  assigneeId               String?      @db.Uuid
  rank                     String       @default("0000000000001000")
  version                  Int          @default(1)
  manualRiskLevel          RiskLevel?
  riskLevel                RiskLevel?
  riskScore                Int?
  riskReasonsJson          Json?
  riskCalculatedAt         DateTime?
  riskRecalculateAt        DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  archivedAt               DateTime?
  deletedAt                DateTime?

  workspace               Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project                 Project?                   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workflowStage          WorkflowStage?            @relation(fields: [workflowStageId], references: [id], onDelete: SetNull)
  parentTask             Task?                      @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks               Task[]                     @relation("TaskSubtasks")
  milestone              Milestone?                 @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  creator                 User?                      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignee                User?                      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  completedBy             User?                      @relation("TaskCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  dependencyOverriddenBy  User?                      @relation("TaskDependencyOverrider", fields: [dependencyOverriddenById], references: [id], onDelete: SetNull)
  notifications           Notification[]
  checklistItems          ChecklistItem[]
  taskTags                TaskTag[]
  customFieldValues       TaskCustomFieldValue[]
  comments                Comment[]
  attachments             Attachment[]
  predecessorDependencies TaskDependency[]           @relation("DependencyPredecessor")
  successorDependencies   TaskDependency[]           @relation("DependencySuccessor")
  timeLogs                TimeLog[]
  statusHistory           TaskStatusHistory[]
  templateRecurrences     TaskRecurrence[]           @relation("RecurrenceTemplateTask")
  generatedOccurrences    RecurringTaskOccurrence[]  @relation("OccurrenceGeneratedTask")
  riskSnapshots           TaskRiskSnapshot[]
  slaInstances            TaskSlaInstance[]
  automationRuns          AutomationRun[]

  @@unique([workspaceId, taskNumber])
  @@index([workspaceId])
  @@index([workspaceId, status, dueDate])
  @@index([workspaceId, status, completedAt])
  @@index([workspaceId, assigneeId, status, dueDate])
  @@index([workspaceId, projectId, status])
  @@index([workspaceId, projectId, status, rank])
  @@index([workflowStageId, projectId, deletedAt, rank])
  @@index([parentTaskId, subtaskPosition])
  @@index([milestoneId, subtaskPosition])
  @@index([workspaceId, startAt])
  @@index([workspaceId, dueDate])
  @@index([projectId])
  @@index([assigneeId])
  @@index([completedById])
  @@index([dependencyOverriddenById])
  @@index([workspaceId, archivedAt, deletedAt])
  @@index([riskRecalculateAt])
  @@index([workspaceId, riskLevel])
  @@map("tasks")
}

model Milestone {
  id          String          @id @default(uuid()) @db.Uuid
  workspaceId String          @db.Uuid
  projectId   String          @db.Uuid
  name        String
  description String?
  status      MilestoneStatus @default(PLANNED)
  position    Int             @default(0)
  startAt     DateTime?
  dueAt       DateTime?
  completedAt DateTime?
  createdById String?         @db.Uuid
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("MilestoneCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks     Task[]

  @@index([workspaceId, projectId, position])
  @@index([projectId, status, dueAt])
  @@index([createdById])
  @@map("milestones")
}

model SavedView {
  id                 String                @id @default(uuid()) @db.Uuid
  workspaceId        String                @db.Uuid
  ownerUserId        String                @db.Uuid
  name               String
  resourceType       SavedViewResourceType @default(TASK)
  viewType           SavedViewType         @default(LIST)
  visibility         SavedViewVisibility   @default(PRIVATE)
  filtersJson        Json                  @default("{}")
  sortJson           Json                  @default("{}")
  groupByJson        Json                  @default("{}")
  columnsJson        Json                  @default("[]")
  displayOptionsJson Json                  @default("{}")
  configVersion      Int                   @default(1)
  isDefault          Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, ownerUserId, name])
  @@index([workspaceId, ownerUserId, isDefault])
  @@index([workspaceId, ownerUserId, viewType])
  @@map("saved_views")
}

model ProjectMember {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @db.Uuid
  projectId   String      @db.Uuid
  userId      String      @db.Uuid
  projectRole ProjectRole @default(PROJECT_MEMBER)
  joinedAt    DateTime    @default(now())
  addedById   String?     @db.Uuid
