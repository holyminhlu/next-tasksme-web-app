generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  LOCKED
  DISABLED
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
}

enum WorkspaceType {
  PERSONAL
  ORGANIZATION
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OneTimeTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OnboardingType {
  PERSONAL_OWNER
  ORGANIZATION_OWNER
  INVITED_MEMBER
  INVITED_MANAGER
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  AI_QUICK_CAPTURE
  ONBOARDING
}

enum ActivityVisibility {
  WORKSPACE
  ACTOR_ONLY
}

enum ProjectVisibility {
  WORKSPACE
  PRIVATE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_MENTIONED
  TASK_UNBLOCKED
}

enum CustomFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
  MULTI_SELECT
  USER
}

enum AttachmentScanStatus {
  PENDING
  CLEAN
  REJECTED
}

enum DependencyType {
  FINISH_TO_START
}

enum DependencyCompletionPolicy {
  WARN_ONLY
  BLOCK
  BLOCK_WITH_OVERRIDE
}

enum TimeLogSource {
  TIMER
  MANUAL
  IMPORT
}

enum SavedViewResourceType {
  TASK
}

enum SavedViewType {
  LIST
  BOARD
  CALENDAR
  TIMELINE
}

enum SavedViewVisibility {
  PRIVATE
}

model User {
  id                    String     @id @default(uuid()) @db.Uuid
  email                 String     @unique
  passwordHash          String
  fullName              String
  status                UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  passwordChangedAt     DateTime?
  authVersion           Int        @default(0)
  failedLoginAttempts   Int        @default(0)
  lockedUntil           DateTime?
  lastActiveWorkspaceId String?    @db.Uuid
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  memberships              WorkspaceMember[]
  refreshSessions          RefreshSession[]
  ownedWorkspaces          Workspace[]              @relation("WorkspaceOwner")
  oneTimeTokens            OneTimeToken[]
  invitationsSent          WorkspaceInvitation[]    @relation("InvitationInviter")
  auditLogs                AuditLog[]
  activityEvents           ActivityEvent[]
  onboardings              WorkspaceOnboarding[]
  projectMemberships       ProjectMember[]
  tasksCreated             Task[]                   @relation("TaskCreator")
  tasksAssigned            Task[]                   @relation("TaskAssignee")
  tasksCompleted           Task[]                   @relation("TaskCompleter")
  notifications            Notification[]
  notificationPrefs        NotificationPreference[]
  savedViews               SavedView[]
  checklistItemsCreated    ChecklistItem[]          @relation("ChecklistItemCreator")
  checklistItemsCompleted  ChecklistItem[]          @relation("ChecklistItemCompleter")
  tagsCreated              Tag[]                    @relation("TagCreator")
  customFieldValuesUpdated TaskCustomFieldValue[]   @relation("CustomFieldValueUpdater")
  commentsAuthored         Comment[]                @relation("CommentAuthor")
  attachmentsUploaded      Attachment[]             @relation("AttachmentUploader")
  taskDependenciesCreated  TaskDependency[]         @relation("TaskDependencyCreator")
  dependencyOverrides      Task[]                   @relation("TaskDependencyOverrider")
  timeLogs                 TimeLog[]
  taskStatusChanges        TaskStatusHistory[]      @relation("TaskStatusChanger")
  lastActiveWorkspace      Workspace?               @relation("UserLastActiveWorkspace", fields: [lastActiveWorkspaceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([lastActiveWorkspaceId])
  @@map("users")
}

model Workspace {
  id                         String                     @id @default(uuid()) @db.Uuid
  name                       String
  slug                       String                     @unique
  type                       WorkspaceType              @default(ORGANIZATION)
  status                     WorkspaceStatus            @default(ACTIVE)
  ownerId                    String                     @db.Uuid
  industryCode               String?
  usagePurpose               String?
  companySize                String?
  timezone                   String                     @default("UTC")
  locale                     String                     @default("vi")
  logoUrl                    String?
  dependencyCompletionPolicy DependencyCompletionPolicy @default(WARN_ONLY)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?

  owner                   User                     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members                 WorkspaceMember[]
  roles                   Role[]
  invitations             WorkspaceInvitation[]
  onboardings             WorkspaceOnboarding[]
  modules                 WorkspaceModule[]
  projects                Project[]
  tasks                   Task[]
  activityEvents          ActivityEvent[]
  projectMembers          ProjectMember[]
  taskCounter             WorkspaceTaskCounter?
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  savedViews              SavedView[]
  tags                    Tag[]
  customFieldDefinitions  CustomFieldDefinition[]
  attachments             Attachment[]
  taskDependencies        TaskDependency[]
  timeLogs                TimeLog[]
  lastActiveUsers         User[]                   @relation("UserLastActiveWorkspace")

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@map("workspaces")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  key         String
  name        String
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members         WorkspaceMember[]
  rolePermissions RolePermission[]
  invitations     WorkspaceInvitation[]

  @@unique([workspaceId, key])
  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model WorkspaceMember {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  userId      String           @db.Uuid
  roleId      String           @db.Uuid
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId, workspaceId], references: [id, workspaceId])

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([roleId])
  @@index([workspaceId, status])
  @@map("workspace_members")
}

model RefreshSession {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  familyId            String    @db.Uuid
  tokenHash           String    @unique
  expiresAt           DateTime
  absoluteExpiresAt   DateTime
  rememberMe          Boolean   @default(false)
  revokedAt           DateTime?
  revokeReason        String?
  replacedByTokenHash String?
  lastUsedAt          DateTime?
  userAgent           String?
  ipAddress           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_sessions")
}

model OneTimeToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      OneTimeTokenType
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("one_time_tokens")
}

model WorkspaceInvitation {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  email       String
  roleId      String           @db.Uuid
  tokenHash   String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String           @db.Uuid
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId, workspaceId], references: [id, workspaceId])
  invitedBy User      @relation("InvitationInviter", fields: [invitedById], references: [id])

  @@index([workspaceId, email])
  @@index([status])
  @@index([expiresAt])
  @@map("workspace_invitations")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  workspaceId String?  @db.Uuid
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  requestId   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model WorkspaceOnboarding {
  id             String           @id @default(uuid()) @db.Uuid
  workspaceId    String           @db.Uuid
  userId         String           @db.Uuid
  onboardingType OnboardingType
  status         OnboardingStatus @default(IN_PROGRESS)
  currentStep    String
  completedSteps Json             @default("[]")
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([status])
  @@map("workspace_onboardings")
}

model WorkspaceModule {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  moduleKey   String
  enabled     Boolean  @default(true)
  core        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, moduleKey])
  @@index([workspaceId])
  @@map("workspace_modules")
}

model Project {
  id          String            @id @default(uuid()) @db.Uuid
  workspaceId String            @db.Uuid
  name        String
  description String?
  status      String            @default("ACTIVE")
  visibility  ProjectVisibility @default(WORKSPACE)
  createdById String?           @db.Uuid
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks                  Task[]
  members                ProjectMember[]
  customFieldDefinitions CustomFieldDefinition[]

  @@index([workspaceId])
  @@index([workspaceId, status, deletedAt])
  @@index([createdById])
  @@map("projects")
}

model Task {
  id                       String       @id @default(uuid()) @db.Uuid
  workspaceId              String       @db.Uuid
  taskNumber               Int
  projectId                String?      @db.Uuid
  title                    String
  description              String?
  status                   TaskStatus   @default(TODO)
  priority                 TaskPriority @default(MEDIUM)
  startAt                  DateTime?
  dueDate                  DateTime?
  completedAt              DateTime?
  completedById            String?      @db.Uuid
  isBlocked                Boolean      @default(false)
  blockedReason            String?
  dependencyBlocked        Boolean      @default(false)
  dependencyOverrideReason String?
  dependencyOverriddenById String?      @db.Uuid
  dependencyOverriddenAt   DateTime?
  source                   TaskSource   @default(MANUAL)
  createdById              String?      @db.Uuid
  assigneeId               String?      @db.Uuid
  rank                     String       @default("0000000000001000")
  version                  Int          @default(1)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  archivedAt               DateTime?
  deletedAt                DateTime?

  workspace               Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project                 Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator                 User?                  @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignee                User?                  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  completedBy             User?                  @relation("TaskCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  dependencyOverriddenBy  User?                  @relation("TaskDependencyOverrider", fields: [dependencyOverriddenById], references: [id], onDelete: SetNull)
  notifications           Notification[]
  checklistItems          ChecklistItem[]
  taskTags                TaskTag[]
  customFieldValues       TaskCustomFieldValue[]
  comments                Comment[]
  attachments             Attachment[]
  predecessorDependencies TaskDependency[]       @relation("DependencyPredecessor")
  successorDependencies   TaskDependency[]       @relation("DependencySuccessor")
  timeLogs                TimeLog[]
  statusHistory           TaskStatusHistory[]

  @@unique([workspaceId, taskNumber])
  @@index([workspaceId])
  @@index([workspaceId, status, dueDate])
  @@index([workspaceId, status, completedAt])
  @@index([workspaceId, assigneeId, status, dueDate])
  @@index([workspaceId, projectId, status])
  @@index([workspaceId, projectId, status, rank])
  @@index([workspaceId, startAt])
  @@index([workspaceId, dueDate])
  @@index([projectId])
  @@index([assigneeId])
  @@index([completedById])
  @@index([dependencyOverriddenById])
  @@index([workspaceId, archivedAt, deletedAt])
  @@map("tasks")
}

model SavedView {
  id                 String                @id @default(uuid()) @db.Uuid
  workspaceId        String                @db.Uuid
  ownerUserId        String                @db.Uuid
  name               String
  resourceType       SavedViewResourceType @default(TASK)
  viewType           SavedViewType         @default(LIST)
  visibility         SavedViewVisibility   @default(PRIVATE)
  filtersJson        Json                  @default("{}")
  sortJson           Json                  @default("{}")
  groupByJson        Json                  @default("{}")
  columnsJson        Json                  @default("[]")
  displayOptionsJson Json                  @default("{}")
  configVersion      Int                   @default(1)
  isDefault          Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, ownerUserId, name])
  @@index([workspaceId, ownerUserId, isDefault])
  @@index([workspaceId, ownerUserId, viewType])
  @@map("saved_views")
}

model ProjectMember {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  projectId   String   @db.Uuid
  userId      String   @db.Uuid
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([workspaceId, userId])
  @@map("project_members")
}

model WorkspaceTaskCounter {
  workspaceId String   @id @db.Uuid
  nextNumber  Int      @default(1)
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_task_counters")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  userId      String           @db.Uuid
  taskId      String?          @db.Uuid
  type        NotificationType
  title       String
  body        String?
  dedupeKey   String           @unique
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, readAt, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @db.Uuid
  userId        String   @db.Uuid
  taskAssigned  Boolean  @default(true)
  taskMentioned Boolean  @default(true)
  taskUnblocked Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("notification_preferences")
}

model TaskDependency {
  id                String         @id @default(uuid()) @db.Uuid
  workspaceId       String         @db.Uuid
  predecessorTaskId String         @db.Uuid
  successorTaskId   String         @db.Uuid
  dependencyType    DependencyType @default(FINISH_TO_START)
  createdById       String?        @db.Uuid
  createdAt         DateTime       @default(now())

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  predecessorTask Task      @relation("DependencyPredecessor", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTask   Task      @relation("DependencySuccessor", fields: [successorTaskId], references: [id], onDelete: Cascade)
  createdBy       User?     @relation("TaskDependencyCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([predecessorTaskId, successorTaskId, dependencyType])
  @@index([workspaceId, predecessorTaskId])
  @@index([workspaceId, successorTaskId])
  @@map("task_dependencies")
}

model TimeLog {
  id              String        @id @default(uuid()) @db.Uuid
  workspaceId     String        @db.Uuid
  taskId          String        @db.Uuid
  userId          String        @db.Uuid
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  description     String?
  source          TimeLogSource @default(MANUAL)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, endedAt])
  @@index([taskId, startedAt])
  @@index([workspaceId, startedAt, endedAt])
  @@map("time_logs")
}

model TaskStatusHistory {
  id                       String      @id @default(uuid()) @db.Uuid
  taskId                   String      @db.Uuid
  fromStatus               TaskStatus?
  toStatus                 TaskStatus
  changedById              String?     @db.Uuid
  changedAt                DateTime    @default(now())
  durationInPreviousStatus Int?

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User? @relation("TaskStatusChanger", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([taskId, changedAt])
  @@map("task_status_history")
}

model ChecklistItem {
  id            String    @id @default(uuid()) @db.Uuid
  taskId        String    @db.Uuid
  title         String
  isCompleted   Boolean   @default(false)
  position      Int
  completedById String?   @db.Uuid
  completedAt   DateTime?
  createdById   String?   @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  task        Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy   User? @relation("ChecklistItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  completedBy User? @relation("ChecklistItemCompleter", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([taskId, position])
  @@map("checklist_items")
}

model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String
  color       String
  createdById String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("TagCreator", fields: [createdById], references: [id], onDelete: SetNull)
  taskTags  TaskTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

model TaskTag {
  taskId    String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
  @@map("task_tags")
}

model CustomFieldDefinition {
  id               String          @id @default(uuid()) @db.Uuid
  workspaceId      String          @db.Uuid
  projectId        String?         @db.Uuid
  name             String
  fieldType        CustomFieldType
  isRequired       Boolean         @default(false)
  optionsJson      Json            @default("[]")
  defaultValueJson Json?
  position         Int             @default(0)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  workspace Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values    TaskCustomFieldValue[]

  @@index([workspaceId, projectId, position])
  @@index([workspaceId, isActive])
  @@map("custom_field_definitions")
}

model TaskCustomFieldValue {
  taskId        String   @db.Uuid
  customFieldId String   @db.Uuid
  valueJson     Json
  updatedById   String?  @db.Uuid
  updatedAt     DateTime @updatedAt

  task        Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customField CustomFieldDefinition @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  updatedBy   User?                 @relation("CustomFieldValueUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@id([taskId, customFieldId])
  @@index([customFieldId])
  @@map("task_custom_field_values")
}

model Comment {
  id              String    @id @default(uuid()) @db.Uuid
  taskId          String    @db.Uuid
  authorId        String    @db.Uuid
  parentCommentId String?   @db.Uuid
  content         String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  task     Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author   User             @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment?         @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies  Comment[]        @relation("CommentReplies")
  mentions CommentMention[]

  @@index([taskId, deletedAt, createdAt])
  @@index([parentCommentId])
  @@map("comments")
}

model CommentMention {
  id        String   @id @default(uuid()) @db.Uuid
  commentId String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("comment_mentions")
}

model Attachment {
  id               String               @id @default(uuid()) @db.Uuid
  workspaceId      String               @db.Uuid
  taskId           String               @db.Uuid
  uploadedById     String?              @db.Uuid
  originalFileName String
  storageKey       String
  mimeType         String
  sizeBytes        Int
  checksum         String?
  scanStatus       AttachmentScanStatus @default(PENDING)
  createdAt        DateTime             @default(now())
  deletedAt        DateTime?

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([storageKey])
  @@index([taskId, deletedAt, createdAt])
  @@index([workspaceId, deletedAt])
  @@map("attachments")
}

model ActivityEvent {
  id           String             @id @default(uuid()) @db.Uuid
  workspaceId  String             @db.Uuid
  actorId      String?            @db.Uuid
  action       String
  resourceType String
  resourceId   String             @db.Uuid
  projectId    String?            @db.Uuid
  summary      String
  metadata     Json?
  visibility   ActivityVisibility @default(WORKSPACE)
  sensitive    Boolean            @default(false)
  createdAt    DateTime           @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, projectId, createdAt])
  @@index([workspaceId, actorId, createdAt])
  @@map("activity_events")
}
